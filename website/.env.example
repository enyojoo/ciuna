# Website (ciuna.com) environment variables

# App URL (optional) — e.g. deep links to app.ciuna.com
NEXT_PUBLIC_APP_URL=https://app.ciuna.com

# Supabase - required for currency converter (currencies + exchange_rates)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# PostHog - analytics and visitor tracking
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
