# App (app.ciuna.com) environment variables

# App URL - for emails, Bridge redirects, etc.
NEXT_PUBLIC_APP_URL=https://app.ciuna.com

# Site URL - Supabase auth redirectTo (forgot password)
NEXT_PUBLIC_SITE_URL=https://app.ciuna.com

# Office app URL - for CORS on /api/admin/* (bk.ciuna.com)
NEXT_PUBLIC_OFFICE_URL=https://bk.ciuna.com

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# SendGrid
# Admin alerts for new/updated transactions (defaults to enyo@easner.com)
ADMIN_TRANSACTION_NOTIFICATION_EMAIL=enyo@easner.com
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@ciuna.com
SENDGRID_FROM_NAME=Ciuna
SENDGRID_REPLY_TO=support@ciuna.com

# Bridge
BRIDGE_API_KEY=

# JWT (password reset)
JWT_SECRET=
